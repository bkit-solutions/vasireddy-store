{
  "name": "vasireddy-store",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "npm run db:setup && npm run db:push && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:setup": "tsx scripts/setup-db.ts",
    "db:push": "dotenv -e .env.local -- prisma db push --skip-generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev --skip-generate",
    "prisma:generate": "prisma generate",
    "prisma:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "setup:local": "npm run db:setup && npm run db:push && npm run prisma:seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "mysql2": "^3.22.0",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "nodemailer": "^6.10.1",
    "razorpay": "^2.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
